# ============================password=====================
# n8n Environment — Render Free Plan
# Optimized for:
# 0.1 CPU / 512MB RAM
# n8n 1.95.3
# =========================================================


# =========================================================
# HOST / NETWORK
# =========================================================

N8N_HOST=n8n-anas-ali.onrender.com
N8N_PORT=5678
N8N_PROTOCOL=https

WEBHOOK_URL=https://n8n-anas-ali.onrender.com/
N8N_EDITOR_BASE_URL=https://n8n-anas-ali.onrender.com

GENERIC_TIMEZONE=Asia/Dhaka
TZ=Asia/Dhaka


# =========================================================
# SECURITY
# =========================================================

# Generate using:
# openssl rand -hex 32
#
# NEVER CHANGE AFTER DEPLOY
N8N_ENCRYPTION_KEY=AnasAli2026_SuperSecure_Random_Key_ChangeThis_123456789

N8N_SECURE_COOKIE=false
N8N_TRUSTED_PROXIES=0.0.0.0/0

# Allow env access inside Code node
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Recommended security setting
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true


# =========================================================
# MEMORY OPTIMIZATION (512MB RAM)
# =========================================================

# Main Node.js heap limit
NODE_OPTIONS=--max-old-space-size=256 --max-semi-space-size=2

# Store binary data on disk instead of RAM
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Only 1 workflow at a time
N8N_CONCURRENCY_PRODUCTION_LIMIT=1

# Disable task runners completely
# Saves ~100-150MB RAM
N8N_RUNNERS_ENABLED=false


# =========================================================
# EXECUTIONS / PERFORMANCE
# =========================================================

# Auto delete old executions
N8N_PRUNING_ENABLED=true
N8N_PRUNING_EXECUTION_DATA_MAX_AGE=24

# Keep max 500 executions
EXECUTIONS_DATA_PRUNE_MAX_COUNT=500

# Prevent stuck workflows
EXECUTIONS_TIMEOUT=1800
EXECUTIONS_TIMEOUT_MAX=3600

# Disable worker offloading
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=false


# =========================================================
# FEATURES — DISABLED
# =========================================================

N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
N8N_TEMPLATES_ENABLED=false

# Reduce logs
N8N_LOG_LEVEL=warn


# =========================================================
# CODE NODE ACCESS
# =========================================================

NODE_FUNCTION_ALLOW_BUILTIN=*
NODE_FUNCTION_ALLOW_EXTERNAL=*


# =========================================================
# STORAGE
# =========================================================

N8N_DATA_FOLDER=/home/n8n/.n8n


# =========================================================
# BASIC AUTH
# =========================================================

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=890712(anas)


# =========================================================
# DATABASE (OPTIONAL — RECOMMENDED)
# Supabase PostgreSQL
# =========================================================

# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=postgres

# DB_POSTGRESDB_PASSWORD=890712(anas)
# DB_POSTGRESDB_SSL=true
# DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false
